
 ::-webkit-scrollbar {
	width: 0;
	height: 0;
	color: transparent;
	display: none;
}


































































































































































































/* 弹出层默认样式 */
.scroll-popup.data-v-d2e42b46 {
	width: 100%;
	position: fixed;
	bottom: -100%;
	z-index: 999;
}
/* 点击按钮是将盒子 bottom 值归零即可实现弹出效果,
 同理，如需更改弹出方向只需将bottom改成top、left、right即可
 (默认样式的方向也需一起更改哦) */
.scroll-open.data-v-d2e42b46 {
	bottom: 0px !important;
}
.scroll-animation.data-v-d2e42b46 {
	transition: all 0.25s linear;
}
.scroll-temp.data-v-d2e42b46 {
	padding-bottom: env(safe-area-inset-bottom);
}
/* 遮罩层样式 */
.scroll-mask.data-v-d2e42b46 {
	position: fixed;
	top: 0;
	left: 0;
	right: 0;
	bottom: 0;
	background: rgba(0, 0, 0, 0.3);
	z-index: 998;
}
