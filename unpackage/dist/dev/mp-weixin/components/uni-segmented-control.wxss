
.segmented-control {
	display: flex;
	flex-direction: row;
	justify-content: center;
	width: 75%;
	font-size: 28rpx;
	border-radius: 10rpx;
	box-sizing: border-box;
	margin: 0 auto;
	overflow: hidden;
}
.segmented-control.button {
	border: 2rpx solid;
}
.segmented-control.text {
	border: 0;
	border-radius: 0rpx;
}
.segmented-control-item {
	flex: 1;
	text-align: center;
	line-height: 60rpx;
	box-sizing: border-box;
}
.segmented-control-item.button {
	border-left: 1rpx solid;
}
.segmented-control-item.text {
	border-left: 0;
}
.segmented-control-item:first-child {
	border-left-width: 0;
}

