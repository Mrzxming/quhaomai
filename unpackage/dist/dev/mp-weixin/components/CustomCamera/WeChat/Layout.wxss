
.custom-camera {
    height: 100vh;
    background-color: #000;
    flex-direction: column;
}
.camera-wrap {
    position: relative;
    overflow: hidden;
}
.camera-options {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 0 60rpx;
    background-color: rgba(0, 0, 0, 0.65);
}
.camera-item {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex: 1;
    height: 100%;
}
.camera-item-text {
    color: #ffffff;
    font-size: 32rpx;
}
.shutter-button {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    border: 6rpx solid rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
}
.shutter-button-inner {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    background-color: #FE2F02;
}

