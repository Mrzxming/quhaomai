@-webkit-keyframes flicker-data-v-bc70e9d0 {
0% {
		box-shadow: 0 0 0 #FFFFFF;
}

	/** 暂停效果 */
10% {
		box-shadow: 0 0 2rpx #FFFFFF;
}
50% {
		box-shadow: 0 0 10rpx #FFFFFF;
}
60% {
