/*商品清单底部弹窗*/
.show-popup-qingdan .title {
	padding: 20rpx 30rpx 20rpx 20rpx;
}
.commodity {
	height: 100%;
	width: 100%;
}
.commodity_ul {
	padding: 20rpx 30rpx 0 20rpx;
}
.commodity_li {
	border-bottom: 1px solid #f4f4f4;
	margin-bottom: 20rpx;
	padding-bottom: 20rpx;
	display: flex;
	flex-direction: row;
}
.commodity_li:last-child {
