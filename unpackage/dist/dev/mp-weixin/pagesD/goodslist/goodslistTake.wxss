@charset "UTF-8";
/*product-list*/
.uni-product-list {
  padding: 0 18rpx;
  margin-top: 18rpx;
  box-sizing: border-box;
}
.uni-product {
  width: 48.5%;
}
.uni-product-list .uni-product-title {
  font-size: 28rpx;
  height: 80rpx;
}
.uni-product-list .uni-product-title .tag {
  background-color: #ff5256;
  color: #fff;
  padding: 0 10rpx;
  margin-right: 10rpx;
}
.uni-product-list .outer {
  width: 100%;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}
.uni-product-list .outer .left {
  width: 260rpx;
}
.uni-product-list .outer .tag {
  background-color: #fef0f0;
  color: #f92028;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
}
.uni-product-list .outer .sales-volume {
  font-size: 26rpx;
  color: #999999;
}
.uni-product-list .outer .icon-cart {
  color: #f92028;
  font-size: 35rpx;
  margin-right: 10rpx;
}
.uni-product-list .outer-teshu {
  margin-top: 15rpx;
  line-height: 0;
  flex-wrap: inherit;
  display: inherit;
  height: 16px;
  line-height: 16px;
  overflow: hidden;
}
.uni-product-list .outer-teshu .tag {
  padding: 0 10rpx;
  height: 16px;
  line-height: 16px;
  background-color: #f92028;
  color: #FFFFFF;
  float: left;
  margin-right: 10rpx;
  font-size: 12px;
  border-radius: 8rpx;
}
.uni-product-list .outer-teshu .label-list {
  font-size: 0;
  line-height: 0;
  display: inherit;
}
.uni-product-list .outer-teshu .label-list .label-img {
  height: 16px;
  font-size: 0;
  line-height: 0;
}
.product-list-medium .uni-product {
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
}
.product-list-medium .uni-product .image-view {
  width: 220rpx;
  height: 220rpx;
}
.product-list-medium .uni-product-info {
  width: auto;
  flex: 1 1 0%;
}
.label-line {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  font-size: 10px;
  -webkit-transform: scale(0.8);
          transform: scale(0.8);
  margin-left: -40rpx;
  width: 120%;
  margin-top: -10rpx;
}
.label-box .label-box-line {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  padding-bottom: 5px;
  margin: 0 12rpx 0 0;
  text-align: left;
}
.label-box .zero-label {
  color: #FE2F02;
  font-size: 12px;
  font-weight: 400;
  line-height: 12px;
  text-shadow: 0px 0px 6px rgba(0, 0, 0, 0.05);
  font-style: normal;
}
.label-box .zero-tag {
  color: #FF7705;
  font-size: 12px;
  font-weight: 400;
  line-height: 12px;
  text-shadow: 0px 0px 6px rgba(0, 0, 0, 0.05);
  font-style: normal;
}
.label-box .first-label {
  color: #09B248;
  font-size: 12px;
  font-weight: 400;
  line-height: 12px;
  text-shadow: 0px 0px 6px rgba(0, 0, 0, 0.05);
  font-style: normal;
}
.label-box .second-label {
  color: #A2A2A2;
  font-size: 12px;
  font-weight: 400;
  line-height: 12px;
  text-shadow: 0px 0px 6px rgba(0, 0, 0, 0.05);
  font-style: normal;
}
.country_icon {
  width: 43rpx;
  height: 30rpx;
  padding-right: 7rpx;
  position: relative;
  top: 5rpx;
}
.add-cart {
  position: relative;
}
.add_num {
  right: 5px;
}
.image-view {
  position: relative;
}
.bargain-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 25rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 20rpx;
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 3rpx 20rpx;
  color: #FFFfff;
}
.bargain-tag .iconfont {
  line-height: 1;
  margin-right: 10rpx;
}
.uni-product-price .box {
  line-height: 1.5;
}
.uni-product-price .gay {
  color: #999999;
  margin-right: 5rpx;
}
.uni-product-price .del {
  text-decoration: line-through;
  font-size: 24rpx;
}
.uni-product-price .em {
  font-size: 24rpx;
}
.shop_name_class {
  color: #A2A2A2;
  font-size: 26rpx;
  margin-right: 6rpx;
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
/* start--Retina 屏幕下的 1px 边框--start */
.u-border-top,
.u-border-top:after,
.u-border-top:after {
  border-top-width: 1px;
}
/* end--Retina 屏幕下的 1px 边框--end */
/* start--去除button的所有默认样式--start */
.u-reset-button {
  padding: 0;
  font-size: inherit;
  line-height: inherit;
  background-color: transparent;
  color: inherit;
}
.u-reset-button::after {
  border: none;
}
/* end--去除button的所有默认样式--end */
/* 提交订单栏 start */
.sub_btn {
  width: 100%;
  flex: auto;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
  font-size: 15px;
}
.sub_btn .jiage {
  font-weight: normal;
  font-size: 12px;
}
.yellow_btn {
  background-color: #FFC707;
}
.red_btn {
  background-color: #F91F28;
}
/* 优惠弹框 start */
.pop_content {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  background-color: #fff;
}
/* 优惠弹框 end */
/* 商品属性弹框 start */
.goods_attr_pop {
  position: relative;
  padding: 30rpx;
}
.goods_attr_pop .close_img {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 44rpx;
  height: 44rpx;
}
.goods_attr_pop .goods_info {
  display: flex;
}
.goods_attr_pop .goods_info .goods_pic {
  flex: none;
  width: 200rpx;
  height: 200rpx;
  border-radius: 10rpx;
}
.goods_attr_pop .goods_info .info_right {
  flex: auto;
  margin-left: 20rpx;
}
.goods_attr_pop .goods_info .info_right .selece_atrr {
  margin-top: 10rpx;
  line-height: 40rpx;
}
.goods_attr_pop .inventory {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  color: #999;
}
.goods_attr_pop .inventory .inventory_num {
  flex: none;
  margin-right: 20rpx;
  line-height: 40rpx;
}
.goods_attr_pop .inventory .inventory_sn {
  flex: auto;
  display: flex;
  white-space: normal;
  word-break: break-all;
  word-wrap: break-word;
  line-height: 40rpx;
}
.goods_attr_pop .inventory .inventory_sn .label {
  flex: none;
}
.goods_attr_pop .goods_attr_wrap .attr_title {
  font-weight: 700;
}
.goods_attr_pop .goods_attr_wrap .attr_type {
  padding-top: 30rpx;
}
.goods_attr_pop .goods_attr_wrap .attr_list {
  display: flex;
  flex-wrap: wrap;
  width: 720rpx;
}
.goods_attr_pop .goods_attr_wrap .attr_list .attr_item {
  padding: 0 30rpx;
  height: 62rpx;
  line-height: 62rpx;
  text-align: center;
  border-radius: 30rpx;
  margin: 30rpx 30rpx 0 0;
  background-color: #F2F2F2;
}
.goods_attr_pop .goods_attr_wrap .attr_list .active_attr {
  color: #F22E20;
  background-color: #FCEDEB;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun {
  display: flex;
  align-items: center;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun .limit_txt {
  font-size: 24rpx;
  color: #F22E20;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun .add_num_wrap {
  display: flex;
  justify-content: center;
  align-items: center;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun .add_num_wrap .iconfont {
  flex: none;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun .add_num_wrap .limit_1 {
  color: #EAEAEA;
}
.goods_attr_pop .goods_attr_wrap .goods_num_wrap .limit_and_mun .add_input {
  width: 100rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-weight: 400;
  background-color: #F2F2F2;
}
.footer_btn {
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #fff;
  padding: 15rpx 30rpx;
}
.footer_btn .sub_btn:last-child {
  margin-right: 0;
}
.pup_btn {
  flex: 1;
  margin: 0;
}
.pup_btn:nth-child(n+2) {
  margin-left: 30rpx;
}
/* 适配iPhone X */
.IpxBot {
  position: fixed;
  bottom: 160rpx;
  left: 0;
  width: 92%;
}
/* 适配iPhone X */
.IpxBots {
  position: fixed;
  bottom: 106rpx;
  left: 0;
  width: 92%;
}
