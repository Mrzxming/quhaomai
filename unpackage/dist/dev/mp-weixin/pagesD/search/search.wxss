@charset "UTF-8";
page {
  background-color: #FFFFFF;
}
.input_main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0rpx 36rpx;
  width: 75%;
  padding: 15rpx 30rpx 10rpx 30rpx;
  margin: 30rpx 30rpx 0 0;
  margin-top: 25px;
}
.input_view {
  flex: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 70rpx;
  padding: 2rpx 4rpx 2rpx 20rpx;
  color: #828282;
  background-color: #fff;
  border: 1rpx solid #C0C0C0;
  border-radius: 20rpx;
}
.input_view .input {
  width: 380rpx;
}
.input_view .placeholder_text {
  margin-top: -4rpx;
  font-size: 30rpx;
  margin-left: 20rpx;
  width: 400rpx;
}
.input_view .placeholder_texts {
  font-size: 28rpx;
  margin-left: 20rpx;
  background-color: #FE0302;
  color: #ffffff;
  border-radius: 14rpx;
  padding: 6rpx 26rpx;
}
/*header*/
.header {
  border-bottom: solid 1px #e6e6e6;
  height: 50px;
  display: flex;
  backdrop-color: #fff;
  padding: 0 10px;
}
.header .input-view {
  background-color: #FFFFFF;
  border: 1px solid #e6e6e6;
  margin: 9px 9px 9px 0;
  line-height: 30px;
}
.header .button {
  width: 120rpx;
  padding: 0;
  height: 30px;
  margin: 9px 0;
}
/*search*/
.ms-search-wraper {
  position: relative;
}
.history-tags {
  max-height: 256rpx;
  overflow: hidden;
}
.ms-search-head {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 32rpx;
  font-family: PingFangSC, PingFang SC;
  font-weight: 500;
  font-size: 36rpx;
  color: #2D2D2D;
  line-height: 36rpx;
  text-align: justify;
  font-style: normal;
}
.ms-search-head .colse {
  font-size: 25rpx;
  color: #f92028;
}
.ms-search-tags .text {
  padding: 5rpx 25rpx;
  display: inline-block;
  background: #f0f2f5;
  border-radius: 8rpx;
  font-size: 25rpx;
  max-width: 200rpx;
  margin: 0 15rpx 15rpx 0;
}
.history-tags .text {
  display: inline-block;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  max-width: 260rpx;
  margin: 0 16rpx 0 0;
  border-radius: 32rpx;
  border: 1rpx solid #C0C0C0;
  color: #626262;
  border-radius: 32rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0rpx 28rpx;
}
.hot-tags {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
}
.hot-tags .list {
  display: flex;
  align-items: center;
  flex-direction: row;
  width: 45%;
  margin-bottom: 20rpx;
}
.hot-tags .text {
  max-width: 276rpx;
  height: 48rpx;
  background: linear-gradient(270deg, rgba(249, 249, 249, 0) 0%, #F9F9F9 100%);
  line-height: 48rpx;
  border-radius: 8rpx;
  font-weight: 400;
  font-size: 28rpx;
  color: #1B1B1B;
  text-align: left;
  font-style: normal;
  padding: 8rpx 16rpx;
}
.rich-text-border {
  border-top: 1px solid #EDEDED;
  padding: 30rpx 0 34rpx;
  font-family: PingFangSC, PingFang SC;
  font-weight: 400;
  font-size: 32rpx;
  line-height: 32rpx;
  text-align: left;
  font-style: normal;
  display: flex;
  flex-wrap: nowrap;
}
.rich-texts {
  word-break: break-all;
  max-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
.no-bottom-border {
  border-bottom: 1px solid #EDEDED;
  padding: 30rpx 0 34rpx;
  font-family: PingFangSC, PingFang SC;
  font-weight: 400;
  font-size: 32rpx;
  line-height: 32rpx;
  text-align: left;
  font-style: normal;
  display: flex;
  flex-wrap: nowrap;
}
/* 导航栏开始 */
.main-title {
  position: fixed;
  top: -45px;
  left: -18px;
  width: 530PX;
  z-index: 120;
  background-color: #ffffff;
  padding: 0 32rpx;
}
.status_bar {
  background-color: #ffffff;
  height: 25px;
  width: 100%;
}
.overexs {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  autoprefixer: off;
  white-space: normal;
  word-break: break-all;
}
