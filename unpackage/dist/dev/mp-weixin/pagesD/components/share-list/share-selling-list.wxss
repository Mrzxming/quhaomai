@-webkit-keyframes de_add_num {
0% {
		top: -10px;
		opacity: 1
}
50% {
		top: -25px;
		opacity: 1
}
100% {
		top: -25px;
		opacity: 0
}
}
.add_num {
	position: absolute;
	color: #e4393c;
	font-weight: 700;
	top: -10px;
	right: 0;
	display: none;
	font-size: 25rpx;
	pointer-events: none;
	z-index: 30;
}
.add_num.show {
	display: block;
	opacity: 0;
	-webkit-animation: de_add_num 2s;
}
