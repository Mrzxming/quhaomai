  height: 40px;
  background-color: #f9f9f9;
  width: 100%;
}
.search_container .input_main.data-v-0515e7a6 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  line-height: 0;
}
.search_container .input_view.data-v-0515e7a6 {
  flex: auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 70rpx;
  padding: 0 4rpx 0 30rpx;
  border-radius: 14rpx;
