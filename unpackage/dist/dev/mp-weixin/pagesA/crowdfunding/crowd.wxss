.goods-list .goods-left .raise-cate-tag .iconfont.data-v-9ba8bf7c{ font-size: 20rpx;line-height: 1; margin-right: 5rpx;}
.goods-list .goods-cont.data-v-9ba8bf7c{ font-size: 25rpx; color: #999; line-height: 1.5;}
