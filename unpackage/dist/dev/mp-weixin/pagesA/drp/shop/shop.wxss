@charset "UTF-8";
.btnend {
  width: 100%;
  padding: 20rpx 0rpx 50rpx;
  background: #fff;
  border-radius: 20rpx 20rpx 0rpx 0rpx;
  position: relative;
}
.btnend .close_img {
  position: absolute;
  top: 2%;
  right: 4%;
  width: 44rpx;
  height: 44rpx;
}
.btn_wrap {
  height: 80rpx;
  line-height: 80rpx;
  width: 100%;
  border-radius: 34rpx;
  text-align: center;
  font-size: 34rpx;
  border-radius: 30rpx;
  color: #1B1B1B;
}
.current {
  height: 80rpx;
  line-height: 80rpx;
  width: 100%;
  text-align: center;
  font-size: 34rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  color: #FE0302;
  text-align: center;
}
.searchs {
  height: 50px;
  display: flex;
  background: #fff;
  padding: 0 10px;
  margin-top: 16rpx;
  align-items: center;
  position: relative;
}
.searchs .input-view {
  background-color: #FFFFFF;
  border: 1px solid #e6e6e6;
  margin: 9px 9px 9px 0;
  line-height: 30px;
  background: #e6e6e6;
}
.searchs .search {
  background-color: #FFFFFF;
  width: 300rpx;
}
.searchb {
  transition: height 1s ease;
  height: 240rpx;
  color: #FF010C;
}
.seabtns {
  width: 100%;
  height: 50px;
  display: flex;
  background: #fff;
  justify-content: space-between;
  align-items: center;
  text-align: center;
}
.seabtns .seabtn {
  width: 308rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #e6e6e6;
  border-radius: 30rpx;
  color: #1B1B1B;
}
/* 搜索框 */
.header {
  position: relative;
}
.header .bg-img {
  width: 100%;
  height: 250rpx;
  position: relative;
  overflow: hidden;
}
.header .bg-img image {
  width: 100%;
}
.header .bg-img .share {
  background: linear-gradient(to right, #FF010C, #FF7E0C);
  border-radius: 10px;
  padding: 0 25rpx;
  font-size: 25rpx;
  color: #ffffff;
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  line-height: 2;
}
.header .model-box {
  background: rgba(0, 0, 0, 0.4);
  position: absolute;
  right: 0;
  left: 0;
  top: 0;
  bottom: 0;
}
.header .cont {
  padding: 20rpx;
  left: 0;
  right: 0;
  bottom: -80rpx;
  position: absolute;
  display: flex;
}
.header .cont .left {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  overflow: hidden;
}
.header .cont .left image {
  width: 100%;
  height: 100%;
}
.header .cont .right {
  margin-left: 20rpx;
}
.header .cont .right .tit {
  color: #FFFFFF;
  font-size: 30rpx;
}
.tabs {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0 20rpx;
  background: #FFFFFF;
}
.tabs .item {
  width: 33%;
  text-align: center;
}
.tabs .item .iconfont {
  font-size: 35rpx;
  line-height: 1.5;
}
.tabs .item .tit {
  font-size: 30rpx;
}
.tabs .item.active {
  color: #f92028;
}
