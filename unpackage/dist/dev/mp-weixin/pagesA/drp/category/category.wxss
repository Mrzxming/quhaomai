
.container{ overflow: hidden;}
.header-search{ display: flex; width: calc(100% - 40rpx); padding:0 20rpx; background: #FFFFFF; border-bottom: solid 1px #E0E0E0; position: fixed; top: 0; height: 50px; align-items: center; z-index: 99;}
.header-search .input-view{ background-color: #FFFFFF; border:1px solid #e6e6e6; margin: 9px 9px 9px 0; line-height: 30px;}
.header-search .button{ width: 120rpx; padding: 0; height: 30px; margin: 9px 0;}
.page-body { display: flex; padding-top: 50px; background: #FFFFFF;}
.nav {display: flex;width: 100%;}
.nav-left {width: 28%;border-right: solid 1px #E0E0E0;}
.nav-left-item {height: 100rpx;display: flex;align-items: center;justify-content: center;}
.nav-left-item text{ display: block; width: 100%; text-align: center;
}
.nav-left-item.active { color: #f23030;
}
.nav-left-item.active text{ border-left: 5rpx solid #f23030;
}
.nav-right { width: 72%;}
.nav-right .adv{ width: 100%; height: 240rpx; padding: 0 20rpx; margin-top: 20rpx; box-sizing: border-box;}
.nav-right .adv image{ width: 100%; height: 100%;}
.nav-right .item{ padding: 0 20rpx; overflow: hidden; margin-bottom: -20rpx;}
.nav-right .item .tit{ display: flex; justify-content: center; margin: 15rpx 0 30rpx; position: relative;}
.nav-right .item .tit text{ background: #FFFFFF;position: relative; z-index: 2; padding: 0 10rpx;}
.nav-right .item .tit:after{content: " "; height: 1rpx; width: 45%; background: #E0E0E0; position: absolute; top: 26rpx; z-index: 1;}
.nav-right .item .nav-right-item { width: 33.3%; height: 220rpx;float: left;text-align: center;font-size: 28rpx; position: relative;}
.nav-right .item .nav-right-item image { width: 100rpx;height: 100rpx;}
.custom-checkbox{ z-index: 2; background: #FFFFFF; display: flex; flex-direction: row; justify-content: center; align-items: center;}
.nav-right-item checkbox{ position: absolute; top: 0; left: 0; z-index: 2;}
checkbox {
  -webkit-transform:scale(0.7);
          transform:scale(0.7);
}

