<view class="container"><view class="drp-select"><view class="header"><view class="header-warp"><view class="header-img"><block wx:if="{{drpTeamDetailData.user_picture}}"><image src="{{drpTeamDetailData.user_picture}}"></image></block><block wx:else><image src="{{imagePath.userDefaultImg}}"></image></block></view><view class="header-flex"><view class="shop-name">{{drpTeamDetailData.shop_name}}</view><view class="shop-rank">{{$root.m0+drpTeamDetailData.get_drp_shop.create_time}}</view></view><view data-event-opts="{{[['tap',[['drpSet',['$0'],['drpTeamDetailData.get_drp_shop.id']]]]]}}" class="header-set" bindtap="__e"><view class="iconfont icon-dianpu"></view></view></view></view><view class="cont"><view class="col"><view class="title">{{$root.m1}}</view><view class="num uni-red">{{drpTeamDetailData.sum_money}}</view></view><view class="col"><view class="title">{{$root.m2}}</view><view class="num">{{drpTeamDetailData.now_money}}</view></view></view><block wx:if="{{drpTeamDetailData.parent_id==drpTeamDetailData.top_user_id}}"><view class="money-bottom"><button type="warn" data-event-opts="{{[['tap',[['drpTeam',['$event']]]]]}}" bindtap="__e">{{$root.m3}}</button></view></block></view></view>