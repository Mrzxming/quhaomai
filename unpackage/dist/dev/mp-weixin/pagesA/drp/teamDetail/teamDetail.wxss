
.drp-select .header{ background: linear-gradient(#f84d4d, #fe5b64); padding: 40rpx 20rpx; color: #FFFFFF;}
.drp-select .header-warp{ display: flex; flex-direction: row; align-items: center;
}
.drp-select .header-warp .header-img{ width: 140rpx; height: 140rpx; overflow: hidden; border-radius: 100%; border:2px solid rgba(255,255,255,.6);
}
.drp-select .header-warp .header-img image{ width: 100%; height: 100%;}
.drp-select .header-warp .header-flex{ flex: 1 1 0%; padding: 0 20rpx;}
.drp-select .header-warp .header-flex .shop-name{ font-size: 32rpx;}
.drp-select .header-warp .header-flex .shop-rank{ font-size: 26rpx; color: rgba(255,255,255,.9);}
.drp-select .header-warp .header-set{ margin-top: -50rpx; width: 68rpx; height: 68rpx; background: #d24245; border-radius: 100%; display: flex; justify-content: center; align-items: center;
}
.drp-select .header-time{ margin-top: 10rpx; display: flex; justify-content: flex-end; font-size: 26rpx; line-height: 1;}
.cont{ display: flex; flex-direction: row; justify-content: flex-start; padding: 20rpx; background: #FFFFFF;}
.cont .col{ display: flex;  flex-direction: column; width: 50%;
}
.cont .col .title{ font-size: 30rpx; color: #777;}
.cont .col .num{ font-size: 42rpx;}
.money-bottom{ padding: 30rpx 20rpx;
}

