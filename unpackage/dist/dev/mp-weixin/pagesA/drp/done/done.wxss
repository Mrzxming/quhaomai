
.cashier-desk {}
.cashier-desk .header-title {
	background: #FFFFFF;
	display: flex;
	flex-direction: row;
	justify-content: flex-end;
	align-items: center;
	font-size: 32rpx;
	padding: 10rpx 20rpx;
}
.cashier-desk .header-title .price {
	color: #f92028;
	font-size: 40rpx;
}
.cashier-desk .btn {
	position: fixed;
	margin: 0 60rpx 50rpx;
	bottom: 0;
	left: 0;
	right: 0;
}
.cashier-desk .btn button {
	padding: 0;
	font-size: 32rpx;
	color: #fff;
	border-radius: 50rpx;
	border: 0 !important;
}
.cashier-desk .btn button[disabled] {
	opacity: 0.6;
}
.cashier-desk .btn button::after {
	content: " ";
	width: 0;
	height: 0;
	position: absolute;
	top: 0;
	left: 0;
	border: none;
	-webkit-transform: scale(0);
	transform: scale(0);
	-webkit-transform-origin: 0 0;
	transform-origin: 0 0;
	box-sizing: border-box;
	border-radius: 0;
}
.cashier-content {
	background: #FFFFFF;
	margin-top: 20rpx;
}
.cashier-content .title {
	padding: 20rpx;
	font-size: 32rpx;
}
.flow-done {
	padding-top: 60px;
}
.flow-done-con {
	display: flex;
	flex-direction: column;
	justify-content: center;
	text-align: center;
	align-items: center;
}
.flow-done-con .iconfont {
	font-size: 80px;
	line-height: normal;
}
.flow-done-con .icon-qian {
	color: #EFCE0C;
}
.flow-done-con .icon-hookring2 {
	color: #3ec074;
}
.flow-done-con .flow-done-title {
	font-size: 18px;
	margin-top: 20rpx;
	color: #444444;
}
.flow-done-all {
	margin-top: 30px;
}
.flow-done-all .uni-list-cell-navigate .title,
.flow-done-all .uni-list-cell-navigate .value {
	font-size: 16px;
}
.flow-done-all .btn-bar {
	margin: 0 20px;
}
.flow-done-all .btn-bar .btn {
	box-shadow: none;
}
.weixin-content{ display: flex; justify-content: center; flex-direction: column; text-align: center; margin: 0 60rpx; padding: 150rpx 0;}
.weixin-content .weixin-icon{ width: 120rpx; height: 120rpx; margin: 30rpx auto;}
.weixin-content .weixin-price .text{ font-size: 40rpx;
}
.weixin-content .weixin-price .price{ color: #f92028; font-size: 48rpx; margin-top: 20rpx;}
.weixin-content .weixin-pay-btn button { padding: 0;font-size: 32rpx;color: #fff;border-radius: 50rpx;border: 0 !important; margin-top: 50rpx;}

