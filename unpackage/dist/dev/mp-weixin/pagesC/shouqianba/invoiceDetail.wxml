<view class="container"><view class="uni-card uni-card-not"><view class="uni-list"><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">订单编号：</text><view class="value">{{invoiceDetail.client_sn}}</view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票类型：</text><view class="value receipt"><view class="receipt-title">{{invoiceDetail.inv_type}}</view></view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票抬头：</text><view class="value">{{order_inv_payee}}</view></view></view><block wx:if="{{order_tax_id!=''}}"><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">纳税人识别号：</text><view class="value">{{order_tax_id}}</view></view></view></block><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票内容：</text><view class="value">{{invoiceDetail.inv_content}}</view></view></view></view></view><view class="btn-bar"><button class="btn btn-red" type="primary" data-event-opts="{{[['tap',[['reapply',['$0'],['order_id']]]]]}}" bindtap="__e">换开申请</button></view></view>