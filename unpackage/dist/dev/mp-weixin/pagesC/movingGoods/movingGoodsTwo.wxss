}
.search-tab {
  padding: 46rpx 0rpx 6rpx 20rpx;
  margin: 30rpx 20rpx 10rpx 10rpx;
  font-size: 32rpx;
  color: #000000;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  text-align: center;
  align-items: center;
}
.search_submit {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.search_1 {
  color: #191919;
