
.brand-warp{}
.brand-warp .brand-header{ position: relative; background: #fff;}
.brand-warp .brand-header .bg-img{ width: 100%; position: absolute; top: 0; left: 0; right: 0;}
.brand-warp .brand-header .cont-box{ display: flex; padding: 30rpx 30rpx 0 30rpx; flex-direction: row;}
.brand-warp .brand-header .cont-box .b-img{ width: 50%;}
.brand-warp .brand-header .cont-box .b-con{ width: 50%; display: flex; flex-direction: column;}
.brand-warp .brand-header .cont-box .b-con .top{ display: flex; flex-direction: column; padding: 20rpx 0 0 20rpx;}
.brand-warp .brand-header .cont-box .b-con .top .tit{ color: #FFFFFF; font-size: 36rpx;}
.brand-warp .brand-header .cont-box .b-con .top .subtit{ color: rgba(255,255,255,.5);}
.brand-warp .brand-header .cont-box .b-con .bottom{ padding:60rpx 0 0 20rpx;
}
.brand-warp .brand-header .cont-box .b-con .bottom view{ line-height: 1.5; color: #999;}
.brand-warp .brand-header .cont-box .b-con .bottom .name text{ color: #333333;}
.brand-section{ margin-top: 20rpx; background: #FFFFFF;}
.brand-section .title{ padding: 20rpx; font-size: 32rpx;
}
.swiper{ height: 375px;}
.brand-adv{ display: flex; width: 100%; flex-direction: row;}
.brand-adv .brand-adv-left{ padding: 10rpx; width: 66.6%; flex: 1; box-sizing: border-box;
}
.brand-adv .brand-adv-right{ width: 33.3%; display: flex; flex-direction: column;
}
.brand-section .items{ display: flex; flex-wrap:wrap;}
.brand-section .items .item{ width: 25%; flex: 1; box-sizing: border-box; padding: 20rpx; display: flex; flex-direction: row; justify-content: center; align-items: center;border-bottom: 1px solid #f6f6f9;border-right: 1px solid #f6f6f9;}
.brand-section .items .item-last{ background: #F2031F; color: #FFFFFF;}

