  background-color: #ffffff !important;
  /* 白色不透明 */
}
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .tab-bar1 .tab-item.active text {
  color: #fff !important;
}
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .tab-bar1 .tab-item.active text:after {
  border-bottom-color: #fff;
}
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .placeholder_text {
  color: #444 !important;
}
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .input_view image {
  -webkit-filter: brightness(0.4);
          filter: brightness(0.4);
}
