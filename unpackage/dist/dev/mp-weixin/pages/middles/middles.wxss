  color: #444 !important;
}
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .tab-bar1 .all-text text,
.middles-page .header-with-bg.has-header-bg:not(.header-scrolled) .tab-bar1 .all-text .iconfont {
  color: #444 !important;
}
