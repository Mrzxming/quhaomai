}
.cart-submit .submit-bar-price {
  display: inline-block;
  color: #f92028;
  font-weight: 500;
  font-size: 32rpx;
  word-break: break-all;
  white-space: normal;
  flex-shrink: 0;
  min-width: 0;
}
.cart-submit .submit-bar-sub {
  font-weight: 400;
  font-size: 24rpx;
  color: #FE2F02;
  margin-top: 4rpx;
  word-break: break-all;
  white-space: normal;
  text-align: right;
  width: 100%;
}
