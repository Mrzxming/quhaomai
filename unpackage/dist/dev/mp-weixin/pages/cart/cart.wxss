  width: 100%;
}
.cart-submit .submit-bar-text .submit-bar-text-top .price-wrapper .label-text {
  font-weight: 400;
  font-size: 28rpx;
  color: #626262;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.cart-submit .submit-bar-text .submit-bar-text-top text {
  font-weight: 400;
  font-size: 28rpx;
  color: #626262;
}
.cart-submit .submit-bar-text view {
