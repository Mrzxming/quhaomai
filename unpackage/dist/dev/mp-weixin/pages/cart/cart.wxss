@charset "UTF-8";
/* 防止键盘弹起时页面移动（和 user.vue 一样的方案） */
page {
  background: #F6F6F6;
  width: 100%;
  height: 100%;
}
.container {
  width: 100%;
  height: 100%;
  overflow-x: hidden;
}
/* 导航 start */
.nav_bar .status_bar {
  background-color: #f9f9f9;
  height: 25px;
  width: 100%;
}
/* 导航 end */
::-webkit-scrollbar {
  display: none;
}
.activity-tag {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
}
.parts-tag {
  left: -6rpx;
}
.header-address {
  background-color: #fff;
  margin-bottom: 16rpx;
  width: 95%;
  margin-left: 20rpx;
  margin-top: -10rpx;
  padding: 20rpx;
}
.header-address .header-address-box {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 70%;
  margin-left: 20rpx;
  margin-top: -20rpx;
}
.header-address .header-address-box .clear-out {
  margin-top: 20rpx;
}
.header-address .address-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 80%;
  width: 70%;
  margin-top: 20rpx;
  line-height: 30rpx;
}
.header-address .address-box .iconfont {
  margin-right: 10rpx;
}
.card-goods-group {
  margin-bottom: 16rpx;
  padding: 20rpx 0 20rpx 20rpx;
  background: #FFFFFF;
}
.card-shop-head {
  display: flex;
  flex-direction: column;
  padding: 0 0 20rpx;
  justify-content: space-between;
}
.card-shop-head .head-left {
  display: flex;
  align-items: center;
}
.card-shop-head .head-left .checkbox-con {
  display: flex;
  align-items: center;
  font-weight: 500;
  font-size: 32rpx;
  color: #272727;
  line-height: 28rpx;
  vertical-align: bottom;
  /* 关键：对齐底部基线 */
}
.card-shop-head .head-left .checkbox-con .goods-name-text {
  line-height: 28rpx;
  /* 保持行高一致 */
  display: inline-block;
  vertical-align: bottom;
  /* 关键：对齐底部基线 */
}
.card-shop-head .head-left .checkbox-con .goods-tag {
  background-color: #FE0302;
  color: #ffffff;
  border-radius: 10rpx;
  padding: 0rpx 12rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-left: 10rpx;
  line-height: 28rpx;
  /* 保持行高一致 */
  vertical-align: bottom;
  /* 关键：对齐底部基线 */
}
.card-shop-head .head-left .shop-acquiescel {
  width: 44rpx;
  height: 40rpx;
  margin-right: 6px;
}
.card-shop-head .head-left,
.card-shop-head .head-right {
  display: flex;
  flex-direction: row;
}
.card-shop-head .head-right {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 4rpx 10px 4rpx 30px;
  min-height: -webkit-fit-content;
  min-height: fit-content;
}
.card-shop-head .head-right .head-right-left {
  display: flex;
  align-items: center;
}
.card-shop-head .head-right .head-right-left .full_reduction {
  border-radius: 8rpx;
  border: 2rpx solid #FE0302;
  color: #FE2F02;
  margin-right: 8px;
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 6rpx;
  /* 增加垂直内边距 */
  line-height: 1.1;
  padding: 4rpx 8rpx;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.card-shop-head .head-right .head-right-left .use_coup_info {
  font-weight: 400;
  font-size: 28rpx;
  color: #999999;
  line-height: 1;
}
.card-shop-head .head-right .more {
  display: flex;
  align-items: center;
}
.checkbox-icon .uni-icon {
  display: block;
}
.card-act-goods {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}
.card-act-goods:last-child {
  margin-bottom: 0;
}
.cart-act-title {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx 20rpx 60rpx;
}
.cart-act-title .txt {
