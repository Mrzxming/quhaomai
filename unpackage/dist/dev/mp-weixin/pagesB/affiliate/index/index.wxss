.drp-info{ height: calc(100vh - 44px) !important; background: linear-gradient(0deg, #565555, #1c1c1c);
}
.drp-warp{ padding: 20rpx 20rpx 120rpx 20rpx;}
.drp-warp .header{padding: 20rpx; background-size: 100% 100%; border-radius: 20rpx; margin-bottom: 20rpx;}
.drp-warp .header-top{ display: flex; flex-direction: row; justify-content: flex-start; align-items: center;
}
.drp-warp .header-top .header-img{ width: 120rpx; height: 120rpx; overflow: hidden; border-radius: 100%; border:5rpx solid rgba(255,255,255,.3);
}
.drp-warp .header-top .header-right{ flex: 1; margin-left: 20rpx;
}
.drp-warp .header-top .header-right .rank{ display: flex; flex-direction: row; justify-content: space-between; align-items: center;
}
.drp-warp .header-top .header-right .vip{ display: flex; flex-direction: row; justify-content: flex-start; align-items: center; background: linear-gradient(0deg, #151515, #2a2724); padding: 0 25rpx 0 20rpx; border-radius: 50rpx; margin-top: 5rpx;}
.drp-warp .header-top .header-right .time{ font-size: 25rpx; color: #666666;}
.drp-warp .header-top .header-right .rank .more{ color: #666666;}
.drp-warp .header-top .header-right .vip .icon{ width: 40rpx; height: 40rpx; margin-right: 10rpx;}
.drp-warp .header-top .header-right .vip text{ color: #E3C49E;}
.affiliate-items{ margin: -120rpx 20rpx;
}
.section{ background: #FFFFFF; box-shadow: 0 10rpx 30rpx 0 rgba(68, 79, 90, 0.11); border-radius: 20rpx; margin-bottom: 20rpx; overflow: hidden;}
.section .tit{ padding: 10rpx 20rpx; color: #805223; border-bottom: 2rpx solid #E3D6C4; display: flex; flex-direction: row; justify-content: space-between; align-items: center;
}
.section .items{ display: flex; flex-direction: row; justify-content: flex-start; align-items: center;}
.section .item{ flex: 1; width: 25%; padding: 25rpx 0; display: flex; flex-direction: column; justify-content: center; align-items: center;}
.section .item .txt{ color: #AC8054; font-weight: 500;}
.section .item:first-child .txt{ color: #F2041A;}
.section .item .span{ color: #232323; font-size: 25rpx;}
.invite_friends_button{ width: 90%; height: 100rpx; line-height: 100rpx; background: linear-gradient(118deg, #ecd8be, #dbb280); border-radius: 50rpx; color: #805223; font-size: 40rpx; text-align: center; margin:20rpx auto 40rpx; font-weight: 600; display: flex; flex-direction: row; justify-content: center; align-items: center;}
.invite_friends_button text{ margin-right: 10rpx;}
.invite_friends_button .uni-icon{ height: 100rpx; line-height: 110rpx; display: block;}
.nav-items{ display: flex; flex-direction: row; justify-content: space-between; align-items: center; flex-wrap: wrap; margin: 145rpx 20rpx 0rpx;}
.nav-items .item{ width: 48.5%; padding: 20rpx; margin-bottom: 20rpx; display: flex; flex-direction: row; justify-content: flex-start; align-items: center; background: #FFFFFF; box-shadow: 0 10rpx 20rpx 0 rgba(95, 95, 95, 0.1); border-radius: 10rpx; box-sizing: border-box;}
.nav-items .item .icon{ width: 80rpx; height: 80rpx; margin-right: 20rpx;}
.nav-items .item text{ height: 80rpx; line-height: 80rpx; color: #805223;}
.protection .value{
	border-radius: 20rpx;
	display: flex;
	flex-direction: row;
	padding: 20rpx 20rpx 0 20rpx;
	font-size: 24rpx;
	flex-wrap: wrap;
}
.protection .value .item-list{
	width: 25%;
	text-align: center;
	margin-bottom: 20rpx;
	box-sizing: border-box;
}
.protection .value .item-list .icon{
	width: 100%;
	border-radius: 50%;
	width: 130rpx;
	height: 130rpx;
	margin: 0 auto;
}
.protection .value .item-list .icon .img{ border-radius: 50%;
}
.protection .value .item-list .text{
	margin-top: 10rpx;
	width: 100%;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
}

