
.user-consult{ padding:20rpx;}
.cons-list{ display: flex; flex-direction: row; margin-bottom: 50rpx;}
.cons-list .content{ flex: 1; text-align: right; margin-right: 20rpx;}
.cons-list .content .name{ font-size: 25rpx; color: #666666;}
.cons-list .content .msg{ float: right;}
.cons-list .content .cons-cont{ background: #e7e8ef; color: #333333; border-radius: 10rpx; padding: 10rpx 20rpx; position: relative;}
.cons-list .content .cons-cont:after{ content: " "; display: block; position: absolute; width: 20rpx; height: 20rpx; top: 20rpx; -webkit-transform: rotate(45deg); transform: rotate(45deg);}
.cons-list .cons-head-img{ width: 100rpx; height: 100rpx; border-radius: 100%; overflow: hidden;}
.cons-list-2 .cons-head-img{ background: #e7e8ef; display: flex; justify-content: center; align-items: center; margin-right: 20rpx;}
.cons-list-2 .cons-head-img .iconfont{ font-size: 42rpx;color: #a6a6a6;}
.cons-list-2 .content{ text-align: left;
}
.cons-list-2 .content .msg{ float: left;
}
.cons-list-2 .content .cons-cont{ background: #ec5151; color: #FFFFFF;}

