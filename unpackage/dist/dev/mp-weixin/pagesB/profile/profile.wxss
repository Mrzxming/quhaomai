/* 确保内容区域可滚动 */
scroll-view {
  box-sizing: border-box;
}

/* 复选框样式 */
checkbox {
  margin-right: 10rpx;
}

/* 按钮禁用样式 */
.add_box3_a_sx[disabled] {
  background-color: #ccc !important;
}

/* 系统通知图标和内容样式 */
.notification-content {
  display: flex;
  align-items: center;
}
.notification-icon {
  width: 46rpx;
  height: 46rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

