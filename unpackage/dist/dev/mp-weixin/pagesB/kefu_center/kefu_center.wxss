/* iOS风格底部输入栏 */
.kefu-bottom .footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F7F7F7;
  padding: 16rpx 20rpx;
  padding-bottom: 40rpx;
  /* iOS风格轻微阴影 */
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}
/* 图标按钮 - iOS风格 */
.kefu-bottom .footer-icon-btn {
  display: flex;
  align-items: center;
