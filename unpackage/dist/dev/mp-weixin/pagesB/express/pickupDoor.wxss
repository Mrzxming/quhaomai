}
.texts {
  height: 200rpx;
  border-radius: 16rpx;
  border: 1rpx solid #979797;
}
.texts textarea {
  padding: 24rpx;
  font-weight: 400;
  font-size: 28rpx;
  line-height: 24rpx;
  text-align: left;
  font-style: normal;
  width: 92%;
}
.toSubmit {
  background: #FFFFFF;
  box-shadow: 0rpx -2rpx 4rpx 0rpx rgba(192, 192, 192, 0.16);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 26rpx 32rpx 54rpx;
}
.privacy {
