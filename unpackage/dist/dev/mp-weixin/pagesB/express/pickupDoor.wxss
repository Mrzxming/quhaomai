  font-size: 32rpx;
}
.ji_info .ji_top text {
  margin-left: 20rpx;
  min-width: 100rpx;
  max-width: 260rpx;
}
.ji_info .ji_addr {
  font-family: PingFangSC, PingFang SC;
  font-weight: 400;
  font-size: 28rpx;
  color: #A2A2A2;
  line-height: 40rpx;
  text-align: left;
  font-style: normal;
}
.addrImg {
  min-width: 36rpx;
