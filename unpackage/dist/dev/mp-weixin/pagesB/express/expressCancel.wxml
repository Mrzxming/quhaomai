<view class="container"><view class="head-status mbot32 mtop32"> 请告知我们取消原因，我们将做得更好 </view><view class="body"><view class="title"> 取消原因： </view><view class="uni-list"><radio-group><block wx:for="{{alllist}}" wx:for-item="item" wx:for-index="index" wx:key="index"><label data-event-opts="{{[['tap',[['allChange',['$0'],[[['alllist','',index]]]]]]]}}" class="uni-list-cell uni-list-cell-pd" bindtap="__e"><view><radio value="{{item.type}}" color="#f92028" name="{{item.type}}"></radio></view><view>{{item.msg}}</view></label></block></radio-group></view><view hidden="{{!(showOther)}}" style="margin-left:40rpx;"><view class="uni-list"><radio-group data-event-opts="{{[['change',[['otherChange',['$event']]]]]}}" bindchange="__e"><block wx:for="{{otherlist}}" wx:for-item="other" wx:for-index="indexa" wx:key="indexa"><label class="uni-list-cell uni-list-cell-pd"><view><radio value="{{other}}" color="#f92028"></radio></view><view>{{other}}</view></label></block></radio-group></view></view></view><view class="btn-goods-actionnew"><view class="btn-bar"><view data-event-opts="{{[['tap',[['toCancel']]]]}}" class="btn btn-gray" bindtap="__e">暂不取消</view><view data-event-opts="{{[['tap',[['toApply']]]]}}" class="btn btn-red" bindtap="__e">确认取消</view></view></view></view>