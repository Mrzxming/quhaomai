<view class="snapshot-page" style="{{(pageStyle)}}"><view class="wx_nav_bar" style="{{'padding-top:'+(menuButtonInfo.top+'px')+';'}}"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="wx_nav_left" bindtap="__e"><text class="iconfont icon-find-fanhui"></text></view><view class="wx_nav_title">交易快照</view></view><block wx:if="{{$root.g0}}"><view class="swiper_wrap"><view class="swiper_warp_layer"><swiper class="swiper" circular="{{true}}" current="{{current}}" interval="{{3000}}" duration="{{1000}}" data-event-opts="{{[['change',[['changeSwiper',['$event']]]]]}}" bindchange="__e"><block wx:for="{{swiperData}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({index})}}" bindtap="__e"><image class="swiper_img" src="{{item.img_url}}" data-event-opts="{{[['error',[['handleImageError',['$0',index],[[['swiperData','',index]]]]]]]}}" binderror="__e"></image></view></swiper-item></block></swiper><block wx:if="{{$root.g1>1}}"><view class="indicator_dots"><text class="curr_dots">{{currSwiperPic+1}}</text>{{"/"+$root.g2+''}}</view></block></view></view></block><block wx:if="{{snapshotInfo&&snapshotInfo.goods_name}}"><view class="goods_name_wrap"><view class="goods_name">{{snapshotInfo.goods_name}}</view></view></block><view class="snapshot-tip"><view class="tip-content"> 当前页面为订单快照,包含订单创建时的商品描述和下单信息,买卖双方和平台在发生交易争议时,将作为判定依据。 </view><block wx:if="{{snapshotInfo&&snapshotInfo.goods_id}}"><view data-event-opts="{{[['tap',[['viewLatestGoods',['$event']]]]]}}" class="tip-link" bindtap="__e"> 查看最新商品详情 </view></block></view><block wx:if="{{snapshotInfo&&snapshotInfo.shop_name}}"><view class="shop-info"><view class="shop-name">{{snapshotInfo.shop_name}}</view><block wx:if="{{snapshotInfo.shop_id&&snapshotInfo.shop_id>0}}"><view data-event-opts="{{[['tap',[['goToShop',['$event']]]]]}}" class="shop-btn" bindtap="__e">进店逛逛</view></block></view></block><block wx:if="{{snapshotInfo}}"><view class="goods-detail"><view class="detail-title">商品介绍</view><block wx:if="{{snapshotInfo.goods_desc}}"><view class="detail-content"><rich-text nodes="{{snapshotInfo.goods_desc}}" user-select="{{false}}"></rich-text></view></block><block wx:else><view class="detail-empty">暂无商品详情</view></block></view></block></view>