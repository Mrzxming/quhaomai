.account{padding:30rpx}.account .purse-header-box{padding:20rpx;width:100%;box-sizing:border-box;border-radius:10rpx;background-color:#0196fd;box-shadow:0 4px 18px rgba(0,128,248,.4)!important;color:#fff}.account .purse-header-box .value{display:flex;flex-direction:row;justify-content:space-between;align-items:center}.account .purse-header-box .value .money{font-size:40rpx}.account .purse-header-box .value .frozen-money{padding:0 20rpx;border:1px solid #80ccff;height:20px;line-height:20px;border-radius:10px;font-size:25rpx}.account .purse-header-box .user-money-list{display:flex;flex-direction:row;margin-top:50rpx}.account .purse-header-box .user-money-list .money-item{flex:1 1 0%}.account .user-pur-box{padding:20rpx;margin-top:20rpx;background-color:#fff;display:flex;flex-direction:row;border-radius:10rpx}.account .user-pur-box .item{flex:1 1 0%;display:flex;flex-direction:row;align-items:center;justify-content:center}.account .user-pur-box .item:first-child image{width:26px;height:17px;margin-right:20rpx}.account .user-pur-box .item:last-child image{width:18px;height:17px;margin-right:20rpx}.account .my-nav-box{margin-top:20rpx;border-radius:10rpx;background:#fff}.account .my-nav-box .item{display:flex;padding:20rpx;border-bottom:1px solid #f6f6f9;justify-content:space-between;align-items:center}.account .my-nav-box .item .tit .iconfont{margin-right:10rpx;font-size:14px}.user-money-list-item{margin-left:20rpx}