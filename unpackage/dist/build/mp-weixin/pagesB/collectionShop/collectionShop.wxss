.shop{display:flex;flex-direction:column}.shop-top{padding:20rpx;display:flex;flex-direction:row;justify-content:space-between;align-items:center;margin-bottom:20rpx;background:#fff}.shop-top .left{flex:1;display:flex;flex-direction:row;justify-content:flex-start;align-items:center}.shop-top .left image{width:105rpx;height:105rpx}.shop-top .left .info{margin-left:20rpx}.shop-top .left .info view{line-height:1.6}.shop-top .left .info .name{width:100%;font-weight:700}.shop-top .left .info .out{color:#999}.shop-top .right{display:flex;flex-direction:row}.shop-top .right .btn{padding:5rpx 20rpx;border:1px solid #ddd;margin-right:10rpx}.shop-top .right .btn:last-child{margin-right:0}.shop-score{display:flex;flex-direction:row;align-items:center;padding:0 20rpx}.shop-score view{flex:1;justify-content:center;margin-top:10rpx}.shop-score .tit{color:#999;margin-right:20rpx}.shop-score .score{color:#f92028}