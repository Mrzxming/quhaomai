.privacy{height:100vh;background:#fff;padding:0 30rpx;overflow:hidden}.privacy .title{height:60rpx;font-size:40rpx;color:#333;text-align:center;padding:30rpx 0}.privacy .privacy-btn{position:fixed;bottom:100rpx;left:20rpx;right:20rpx;padding-bottom:env(safe-area-inset-bottom)}.privacy .privacy-btn .btn{margin:0 20rpx;height:70rpx;line-height:70rpx;font-size:25rpx}.privacy .uni-popup-middle{height:auto;padding:0;text-align:center}.privacy .uni-popup-middle .icon{font-size:80rpx;color:#f92028;height:80rpx;line-height:80rpx}.privacy .uni-popup-middle .text{padding:10rpx 30rpx 30rpx;font-size:25rpx;text-align:center;color:#666}.privacy .uni-popup-middle .bottom{background:#f6f6f9;color:#f92028;width:100%;text-align:center;font-size:25rpx;padding:10rpx 0;border-radius:0 0 10rpx 10rpx}