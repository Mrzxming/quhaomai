ound:#fc0017;color:#fff;height:70rpx;line-height:70rpx;padding:0 20rpx;border-radius:10rpx;margin-right:25rpx}rich-text .new_message_list{display:flex}rich-text .new_message_list .title-img{max-width:180rpx;max-height:180rpx}rich-text .new_message_list .left_goods_info{margin-left:20rpx;word-wrap:break-word;white-space:normal;word-break:break-all}rich-text .new_message_list .left_goods_info ._span{margin-top:20rpx}.goods_link{margin:10rpx;padding:20rpx;background-color:#e7e8ef;display:flex;border-radius:10rpx;width:100%}.goods_link .goods_link_left{line-height:0;font-size:0}.goods_link .goods_link_left image{max-width:180rpx;max-height:180rpx}.goods_link .goods_link_right{flex:1;margin-left:20rpx;display:flex;flex-flow:column;justify-content:space-between}.goods_link .goods_link_right .goods_link_right_footer{display:flex;justify-content:space-between}.goods_link .goods_link_right .send_link{padding:2rpx 30rpx;background-color:red;color:#fff;border-radius:30rpx}