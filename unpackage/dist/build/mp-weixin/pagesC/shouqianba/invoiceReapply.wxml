<view class="container"><view class="uni-card uni-card-not"><view class="uni-list"><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">订单号：</text><view class="value"><input name="order_sn" disabled="true" data-event-opts="{{[['input',[['__set_model',['$0','order_sn','$event',[]],['order']]]]]}}" value="{{order.order_sn}}" bindinput="__e"/></view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票类型：</text><view class="value"><input name="inv_type" disabled="true" data-event-opts="{{[['input',[['__set_model',['','inv_type','$event',[]]]]]]}}" value="{{inv_type}}" bindinput="__e"/></view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票内容：</text><view class="value"><input name="inv_content" disabled="true" data-event-opts="{{[['input',[['__set_model',['','inv_content','$event',[]]]]]]}}" value="{{inv_content}}" bindinput="__e"/></view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">发票抬头：</text><view class="value"><radio-group data-event-opts="{{[['change',[['invValueRadioHandle',['$event']]]]]}}" bindchange="__e"><view class="uni-list-cell-flex"><label class="uni-list-cell uni-list-cell-not"><view><radio value="0" checked="{{inv_company==0}}"></radio></view><view>个人</view></label><label class="uni-list-cell uni-list-cell-not"><view><radio value="1" checked="{{inv_company==1}}"></radio></view><view>单位</view></label></view></radio-group></view></view></view><block wx:if="{{inv_company==1}}"><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">公司名称：</text><view class="value"><input name="inv_name" placeholder="请填写公司名称" data-event-opts="{{[['input',[['__set_model',['','inv_name','$event',[]]]]]]}}" value="{{inv_name}}" bindinput="__e"/></view></view></view></block><block wx:if="{{inv_company==1}}"><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">纳税人识别号：</text><view class="value"><input name="inv_name" placeholder="请填写税号" data-event-opts="{{[['input',[['__set_model',['','inv_name','$event',[]]]]]]}}" value="{{inv_name}}" bindinput="__e"/></view></view></view></block><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">手机：</text><view class="value"><input name="mobile" placeholder="请填写手机号码" data-event-opts="{{[['input',[['__set_model',['','mobile','$event',[]]]]]]}}" value="{{mobile}}" bindinput="__e"/></view></view></view><view class="uni-list-cell uni-list-cell-title uni-list-cell-right"><view class="uni-list-cell-navigate"><text class="title">邮箱：</text><view class="value"><input name="email" placeholder="请填写邮箱" data-event-opts="{{[['input',[['__set_model',['','email','$event',[]]]]]]}}" value="{{email}}" bindinput="__e"/></view></view></view></view></view><view class="btn-bar"><block wx:if="{{apply_status>=0}}"><button class="btn" type="primary">已申请</button></block><block wx:else><button class="btn btn-red" type="primary" data-event-opts="{{[['tap',[['onSubmit',['$event']]]]]}}" bindtap="__e">提交</button></block></view></view>