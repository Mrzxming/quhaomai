.live-list .live-item{margin:20rpx 20rpx 40rpx;background:#fafafa;border-radius:10rpx;overflow:hidden}.live-list .live-item.active{background:#fff}.live-list .live-item .left{width:280rpx;height:280rpx;position:relative;border-radius:10rpx 0 0 10rpx;overflow:hidden;float:left}.live-list .live-item .left .image{width:280rpx;height:280rpx}.live-list .live-item .left .tips{position:absolute;top:20rpx;left:10rpx;right:0;font-size:25rpx;display:flex;flex-direction:row;width:100rpx;border-radius:5rpx;overflow:hidden}.live-list .live-item .right{width:calc(100% - 320rpx);padding:0 0 0 20rpx;float:left}.live-list .live-item .right .name{font-size:26rpx;margin-top:20rpx}.live-list .live-item .right .scroll-view-product{height:150rpx;margin-top:15rpx}.live-list .live-item .right .goods-item{position:relative;width:150rpx;height:150rpx;margin-right:20rpx;border-radius:10rpx;overflow:hidden;display:inline-block}.live-list .live-item .right .goods-item .image{width:150rpx;height:150rpx}.live-list .live-item .right .goods-item .price{position:absolute;bottom:0;left:0;right:0;text-align:center;line-height:2;font-size:25rpx;background:rgba(0,0,0,.3);color:#fff}.live-list .live-item .right .time{line-height:1.5}.live-list .live-item .right .info .btn{display:inline-block;background:#fff;border-radius:5rpx;padding:0 20rpx 0 40rpx;position:relative;color:#333;margin-top:10rpx}.live-list .live-item .right .info .btn:after{content:"";position:absolute;width:15rpx;height:15rpx;border-radius:50%;background:#f92e28;top:18rpx;left:15rpx}