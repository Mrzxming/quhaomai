.com-nav{margin-bottom:15rpx;background:#fff}.com-nav .com-hd{display:flex;flex-direction:row;justify-content:flex-start;align-items:center;padding:20rpx}.com-nav .com-hd .com-img{width:80rpx;height:80rpx;border-radius:50%;overflow:hidden}.com-nav .com-hd .com-info{display:flex;flex-direction:column;margin-left:20rpx}.com-nav .com-hd .com-info .tit{color:#007aff;font-size:28rpx}.com-nav .com-hd .com-info .txt{color:#aaa;font-size:25rpx}.com-nav .com-bd .com-min-tit{display:flex;padding:0 20rpx 20rpx;flex-direction:row;justify-content:flex-start;align-items:center}.com-nav .com-bd .com-title{font-weight:700;color:#333;margin-left:10rpx}.com-nav .com-fd{display:flex;flex-direction:row;justify-content:center;align-items:center;border-top:2rpx solid #f6f6f9}.com-nav .com-fd .com-icon{width:33.3%;display:flex;flex-direction:row;justify-content:center;align-items:center}.com-nav .com-fd .com-icon .text{color:#888;font-size:25rpx;margin-left:10rpx}