.uni-navbar{display:block;position:relative;width:100%;background-color:#fff}.uni-navbar-shadow{box-shadow:0 1px 6px #ccc}.uni-navbar.uni-navbar-fixed{position:fixed;z-index:998}.uni-navbar-header{display:flex;flex-direction:row;width:100%;height:44px;line-height:44px;font-size:16px}.uni-navbar-header .uni-navbar-header-btns{display:inline-flex;flex-wrap:nowrap;flex-shrink:0;width:120rpx;padding:0 20rpx}.uni-navbar-header .uni-navbar-header-btns:first-child{padding-left:0}.uni-navbar-header .uni-navbar-header-btns:last-child{width:48rpx;padding-left:0rpx}.uni-navbar-container{width:100%;margin:0 20rpx}.uni-navbar-container-title{font-size:36rpx;text-align:center}.uni-mp-navbar{position:relative;display:flex;justify-content:flex-start;align-items:center}.uni-mp-navbar .mp-navbar-warp{display:flex;flex-direction:row;align-items:center;justify-content:center}.uni-mp-navbar .mp-navbar-warp .iconfont{color:#000;font-weight:700;padding-left:20rpx}.uni-mp-navbar .mp-navbar-warp .icon-menu{padding-left:40rpx;font-size:40rpx;margin-top:-9rpx}.uni-mp-navbar .menu-warp{position:absolute;background:#fff;top:100rpx;left:20rpx;display:flex;flex-direction:column;z-index:100;box-shadow:0 0 2px rgba(61,52,75,.5);width:220rpx;border-radius:10rpx;z-index:999}.uni-mp-navbar .menu-warp .list{padding:10rpx 30rpx;border-bottom:2rpx solid #f1f0f6;color:#666;display:flex;flex-direction:row;justify-content:flex-start;align-items:center}.uni-mp-navbar .menu-warp .list:last-child{border-bottom:0}.uni-mp-navbar .menu-warp .list .iconfont{color:#666;margin-right:20rpx}.uni-mp-navbar .menu-warp::after{content:"";position:absolute;display:inline-block;top:-12rpx;left:80rpx;width:0;height:0;border-style:solid;border-width:12rpx;border-color:transparent transparent #fff #fff;-webkit-transform:rotate(-45deg);transform:rotate(-45deg);box-shadow:1rpx -1rpx 4rpx rgba(61,52,75,.5);background:#fff}.uni-mp-navbar .menu-warp::before{content:"";position:absolute;z-index:3;width:35rpx;height:18rpx;background:#fff;top:0;left:75rpx}.goods-img{position:relative}.goods-img .txt{background:#fff;height:10rpx;width:10rpx;position:absolute;right:-8rpx;top:10rpx;z-index:99;border-radius:50%}.menu-mask{position:fixed;z-index:998;top:0;right:0;bottom:0;left:0;background:transparent}