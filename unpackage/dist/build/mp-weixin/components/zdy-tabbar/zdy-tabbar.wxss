view{padding:0;margin:0;box-sizing:border-box}.tabbar-container{z-index:99999999999;position:fixed;bottom:0;left:0;width:100%;box-shadow:0 0 5px #d1d1d1;background-color:#fff;display:flex;align-items:center;padding:10rpx 0 5rpx 0;color:#1b1b1b}.tabbar-container .tabbar-item{width:20%;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}.tabbar-container .item-active{color:#fe0302}.tabbar-container .center-item{display:block;position:relative}.tabbar-container .tabbar-item .item-top{width:50rpx;height:50rpx;padding:0rpx}.tabbar-container .center-item .item-top{flex-shrink:0;padding:10rpx;width:105rpx;height:105rpx;position:absolute;top:-56rpx;left:calc(50% - 54rpx);border-radius:50%}.tabbar-container .tabbar-item .item-top image{width:100%;height:100%}.tabbar-container .tabbar-item .item-bottom{font-size:24rpx;width:100%}.tabbar-container .center-item .item-bottom{position:absolute;bottom:0rpx}.IpxBot{padding-bottom:60rpx!important}.hondian_class{position:absolute;left:53%;top:-16rpx}