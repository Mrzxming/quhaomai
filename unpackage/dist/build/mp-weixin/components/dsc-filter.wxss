.filter-tab{background:#fff}.filter-items{display:flex;flex-direction:row;height:80rpx}.filter-items .item{display:flex;flex:1 1 0%;justify-content:center;align-items:center}.filter-items .item .iconfont{font-size:20rpx;margin-left:5rpx}.filter-items .item .icon-filter{margin:3px 8rpx 0 0}.filter-items .item.active,.filter-items .item.active .iconfont{color:#f92028}.filter-items .item.a-change .iconfont{-webkit-transform:rotate(-180deg);transform:rotate(-180deg)}