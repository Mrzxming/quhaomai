.shop{background-color:#fff;display:flex;flex-direction:column;padding:20rpx}.shop-top{display:flex;flex-direction:row;justify-content:space-between;align-items:center}.shop-top .left{display:flex;flex-direction:row;justify-content:flex-start;align-items:center}.shop-top .left .image{width:105rpx;height:105rpx}.shop-top .left .info{margin-left:20rpx}.shop-top .left .info .name{width:100%;font-weight:700;line-height:1.6}.shop-top .left .info .out{color:#999;line-height:1.6}.shop-top .right{display:flex;flex-direction:row}.shop-top .right .collect{padding:0 16rpx;border:1px solid #f92028;color:#f92028;border-radius:30rpx;font-size:14px}.shop-top .right .collect.active{color:#ccc;border-color:#ddd}.shop-top .right .btn{padding:5rpx 20rpx;border:1px solid #ddd;margin-right:10rpx}.shop-top .right .btn:last-child{margin-right:0}.shop-score{display:flex;flex-direction:row;align-items:center;padding:0 20rpx}.shop-score .text-left,
.shop-score .text-center,
.shop-score .text-right{flex:1;justify-content:center;margin-top:10rpx}.shop-score .tit{color:#999;margin-right:20rpx}.shop-score .score{color:#f92028}