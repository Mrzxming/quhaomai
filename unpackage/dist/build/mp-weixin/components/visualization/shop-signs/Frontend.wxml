<block wx:if="{{shopInfo}}"><view class="shop-signs"><view class="header"><image class="bg-img" src="{{shopInfo.street_thumb}}" mode="widthFix" alt></image><view class="shop-signs-mask"></view></view><view class="info-nums"><view class="info-head"><view class="icon"><image class="img" src="{{shopInfo.logo_thumb}}"></image></view><block wx:if="{{shopInfo.like_num}}"><text>{{"已有 "+shopInfo.like_num+" 人关注"}}</text></block></view><view class="info-items"><view data-event-opts="{{[['tap',[['$outerHref',['/pagesD/shop/shopGoods/shopGoods?ru_id='+shopId,'app']]]]]}}" class="item" bindtap="__e">全部：<text class="text">{{shopInfo.total}}</text></view><view data-event-opts="{{[['tap',[['$outerHref',['/pagesD/shop/shopGoods/shopGoods?ru_id='+shopId+'&type=store_new','app']]]]]}}" class="item" bindtap="__e">新品：<text class="text">{{shopInfo.new}}</text></view><view data-event-opts="{{[['tap',[['$outerHref',['/pagesD/shop/shopGoods/shopGoods?ru_id='+shopId+'&type=is_promote','app']]]]]}}" class="item" bindtap="__e">促销：<text class="text">{{shopInfo.promote}}</text></view></view></view></view></block>