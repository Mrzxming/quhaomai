@-webkit-keyframes animatedBird{0%{top:0}50%{top:-100%}100%{top:0}}@keyframes animatedBird{0%{top:0}50%{top:-100%}100%{top:0}}.shop-signs .header{width:100%;height:250rpx;overflow:hidden;position:relative}.shop-signs .header .shop-signs-mask{background:rgba(0,0,0,.4);position:absolute;top:0;left:0;right:0;bottom:0;z-index:1}.shop-signs .header .bg-img{width:100%;height:auto;position:absolute;-webkit-animation:animatedBird 20s infinite linear;animation:animatedBird 20s infinite linear}.shop-signs .info-nums{background:#fff;position:relative;z-index:9}.shop-signs .info-nums .info-head{text-align:center;padding-top:80rpx}.shop-signs .info-nums .info-head .icon{position:absolute;width:120rpx;height:120rpx;background:#fff;border-radius:50%;box-shadow:1px 1px 10px rgba(0,0,0,.2);overflow:hidden;top:-60rpx;left:50%;margin-left:-60rpx}.shop-signs .info-nums .info-head .icon .img{border-radius:50%;position:relative;left:0}.shop-signs .info-nums .info-items{display:flex;justify-content:center;align-items:center;padding:20rpx 0;color:#888}.shop-signs .info-nums .info-items .item{width:33.3%;display:flex;justify-content:center;align-items:center}.shop-signs .info-nums .info-items .item .text{color:#333}