.page-section-spacing{position:relative}.page-section{overflow:hidden;line-height:0;font-size:0}.page-section .swiper-item{position:relative;line-height:0;font-size:0}.page-section .swiper-item .image{width:100%}.page-section .swiper-item .desc{box-sizing:border-box;position:absolute;left:10rpx;right:10rpx;bottom:0;background:rgba(0,0,0,.5);color:#fff}.separat-show{display:flex;flex-direction:column;font-size:0;line-height:0;margin-top:-.5px}.separat-show .item{width:100%;position:relative;line-height:0;font-size:0}.separat-show .desc{box-sizing:border-box;position:absolute;left:10rpx;right:10rpx;bottom:0;background:rgba(0,0,0,.5);color:#fff}.separat-show.mini{display:block}.separat-show.mini .item{width:50%;float:left}.slide-new{padding:0 20rpx;position:relative;overflow:hidden}.slide-new .bg-ellipse{border-radius:30% 30%;height:200rpx;position:absolute;top:-80rpx;left:0;right:0;z-index:1}.slide-new .page-section-spacing{position:relative;z-index:2;border-radius:20rpx;overflow:hidden}.dots-container{position:absolute;right:20rpx;bottom:20rpx;display:flex;justify-content:center}.dot{margin:0 6rpx;width:12rpx;height:12rpx;background:rgba(0,0,0,.2);opacity:1;border-radius:6rpx}.dot.active{background:rgba(0,0,0,.5)}.dots-container.pagination-left{justify-content:flex-start}.dots-container.pagination-center{justify-content:center}.dots-container.pagination-right{justify-content:flex-end}.separat-show-new{padding:20rpx 20rpx 0 20rpx}