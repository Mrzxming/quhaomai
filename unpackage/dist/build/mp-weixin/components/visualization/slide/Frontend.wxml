<view class="{{['page-section',(bStyleSel==2)?'slide-new':'']}}"><block wx:if="{{!bSeparateShow}}"><view class="page-section-spacing"><swiper class="swiper" style="{{'height:'+(imgheights+'px')+';'}}" indicator-dots="{{false}}" autoplay="{{autoplay}}" interval="{{interval}}" duration="{{duration}}" data-event-opts="{{[['change',[['slideChange',['$event']]]]]}}" bindchange="__e"><block wx:for="{{module.list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item><view data-event-opts="{{[['tap',[['link',['$0'],[[['module.list','',index]]]]]]]}}" class="swiper-item" bindtap="__e"><block wx:if="{{item.desc!=''}}"><view class="desc">{{item.desc}}</view></block><image class="image" src="{{item.img}}" mode="widthFix" data-event-opts="{{[['load',[['imageLoad',['$event']]]]]}}" bindload="__e"></image></view></swiper-item></block></swiper><view class="{{['dots-container',bPaginationSel]}}"><block wx:for="{{module.list}}" wx:for-item="ad" wx:for-index="index" wx:key="index"><view class="{{['dot',index===activeIndex?'active':'']}}"></view></block></view></view></block><block wx:else><view class="{{['separat-show',(bMiniList)?'mini':'',(bSeparateSel)?'separat-show-new':'']}}"><block wx:for="{{module.list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['link',['$0'],[[['module.list','',index]]]]]]]}}" class="item" bindtap="__e"><block wx:if="{{item.desc!=''}}"><view class="desc">{{item.desc}}</view></block><image style="width:100%;" src="{{item.img||item.goods_img}}" mode="widthFix"></image></view></block></view></block></view>