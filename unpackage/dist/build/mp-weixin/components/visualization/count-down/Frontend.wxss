.page-section-seckill{margin:0 0 15rpx;padding:0 20rpx 0 30rpx;background:#fff}.seckill-section{overflow:hidden}.seckill-section .header{justify-content:space-between;padding:20rpx 0}.seckill-section .header .right{align-items:center}.seckill-section .header .h3{font-size:36rpx;color:#000;margin-right:20rpx}.uni-countdown{display:flex;flex-wrap:nowrap}.new-style{background:transparent;padding:0;margin:0}.seckill-new-style{margin:20rpx 20rpx 0;background-color:#fff;border-radius:20rpx}.seckill-new-style .seckill-header{padding:0}.seckill-new-style .header-top{display:flex;justify-content:space-between;flex-direction:row;align-items:center;padding:40rpx 20rpx 20rpx}.seckill-new-style .header-top .tit-img,.seckill-new-style .header-top .tit-img ._img{width:200rpx;line-height:0}.seckill-new-style .header-top .data{display:flex;flex-direction:row;justify-content:flex-start;align-items:center}.seckill-new-style .header-top .data-txt{font-size:25rpx;margin-right:10rpx}.seckill-new-style .header-top .data-time{font-size:1.4rem}.seckill-new-style .header-top .data-time ._span{display:inline-block;padding:.5rem;background:linear-gradient(-88deg,#ff4f2e,#f91f28);color:#fff;font-size:1.2rem;border-radius:.5rem;min-width:1.5rem}.seckill-new-style .header-top .data-time ._i{font-size:1.2rem;color:#f20d23;font-size:1.6rem;font-weight:700;margin:0 .4rem}.seckill-new-style .header-top .data-time ._strong{font-size:1.2rem;color:#333;font-weight:400;margin-right:1.2rem}.seckill-new-style .header-time-slot{display:flex;padding:20rpx 0}.seckill-new-style .header-time-slot .item{display:flex;flex:1;flex-direction:column;color:#999;justify-content:center;align-items:center;position:relative;padding-bottom:20rpx;line-height:1.5}.seckill-new-style .header-time-slot .item:after{content:" ";position:absolute;height:1px;background-color:#eee;left:0;right:0;bottom:0}.seckill-new-style .header-time-slot .item:first-child:after{left:20rpx}.seckill-new-style .header-time-slot .item:last-child:after{right:20rpx}.seckill-new-style .header-time-slot .item .tit{line-height:1.5;font-weight:700}.seckill-new-style .header-time-slot .item .text{font-size:25rpx;font-weight:400;margin-top:3px}.seckill-new-style .header-time-slot .item.active{color:#f20d28}.seckill-new-style .header-time-slot .item.active .tit{font-size:28rpx}.seckill-new-style .header-time-slot .item.active .text{font-size:28rpx;margin-top:0}.seckill-new-style .header-time-slot .item.active:after{background-color:#f20d28;height:2px;left:20rpx;right:20rpx}.seckill-goods-list{padding:0 20rpx 0}.seckill-goods-list .scroll-view-item{width:30%;padding:10rpx 6rpx;box-sizing:border-box;display:inline-block;position:relative}.seckill-goods-list .scroll-view-item .goods-top{width:100%;position:relative}.seckill-goods-list .scroll-view-item .goods-top .img-box{line-height:1}.seckill-goods-list .scroll-view-item .goods-top .tagicon{position:absolute;top:0;left:0;width:120rpx;z-index:2}.seckill-goods-list .scroll-view-item .goods-info{padding:20rpx 10rpx;text-align:center;line-height:1.5}.seckill-goods-list .scroll-view-item .goods-info .name{font-size:26rpx;color:0;width:100%;display:block}.seckill-goods-list .scroll-view-item .goods-info .price{color:#f20d28;font-weight:500;font-size:28rpx;line-height:1.5;margin-top:10rpx}.seckill-goods-list .scroll-view-item .goods-info .price .em{font-size:25rpx;margin-right:5rpx}.seckill-goods-list .scroll-view-item .goods-info .price-del{text-decoration:line-through;font-size:24rpx;color:#888;line-height:1.5}.seckill-goods-list .scroll-view-item .goods-info .price-del .em{font-size:20rpx;font-style:normal}.seckill-new-style .more{display:flex;flex-direction:row;justify-content:center;align-items:center;padding-bottom:40rpx}.seckill-new-style .more .tit{font-weight:700;color:0}.country_icon{width:43rpx;height:30rpx;padding-right:7rpx;position:relative;top:5rpx}.more-link{display:flex;flex-direction:row;align-items:center}