<view class="container"><view class="box"><view class="title" style="margin-top:10rpx;">申请理由</view><view class="content"><view class="aaa"><textarea class="itemtitle" placeholder="请简要说明您有什么资源可以分销" name="reason" placeholder-style="color:#999999;font-size:28rpx; " maxlength="300" data-event-opts="{{[['input',[['__set_model',['','reason','$event',[]]]]]]}}" value="{{reason}}" bindinput="__e"></textarea><view class="conlen">{{length+"/300"}}</view></view></view></view><view class="box"><view class="title">证明材料<text style="margin-left:16rpx;font-weight:400;font-size:28rpx;color:#999999;line-height:32rpx;text-align:left;">（最多可上传3张图片）</text></view></view><view class="icon-content"><block wx:for="{{photoList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="icon-item"><view class="itemlist" style="width:100%;display:flex;justify-content:space-between;"><view><image style="height:176rpx;width:176rpx;" src="{{item}}" data-event-opts="{{[['tap',[['handesImage',[index]]]]]}}" bindtap="__e"></image></view><view data-event-opts="{{[['tap',[['cutCheckeds',[index,'$0'],[[['photoList','',index]]]]]]]}}" class="radios" bindtap="__e"><image style="height:40rpx;width:40rpx;border-radius:50rpx;" src="/static/closec.png"></image></view></view></view></block><view data-event-opts="{{[['tap',[['goAdd',['$event']]]]]}}" style="margin:10rpx;" bindtap="__e"><image style="width:176rpx;height:176rpx;" src="/static/addimg.png"></image></view></view><view data-event-opts="{{[['tap',[['subInfo',['$event']]]]]}}" class="submit" bindtap="__e"><view class="subtext">提交</view></view></view>