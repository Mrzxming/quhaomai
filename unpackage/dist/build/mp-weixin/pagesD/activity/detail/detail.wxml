<block wx:if="{{activityShowsData}}"><view class="activity-datail"><view class="pic"><block wx:if="{{activityShowsData.activity_thumb}}"><image class="img" src="{{activityShowsData.activity_thumb}}" mode="widthFix"></image></block><block wx:else><image class="img" src="https://shhai2.oss-cn-shanghai.aliyuncs.com/data/gallery_album/5/original_img/5_P_1705973846451.jpg" mode="widthFix"></image></block></view><view class="title"><text class="tag tag-gradients-color">{{activityShowsData.act_type}}</text><text class="name">{{activityShowsData.act_name}}</text></view><view class="section"><view class="tit">{{$root.m0}}</view><view class="p">{{$root.m1}}<text>{{activityShowsData.start_time+$root.m2+activityShowsData.end_time}}</text></view><view class="p">{{$root.m3}}<text class="text">{{activityShowsData.max_amount}}</text></view><view class="p">{{$root.m4}}<text class="text">{{activityShowsData.min_amount}}</text></view><view class="p">{{$root.m5}}<text class="text">{{activityShowsData.user_rank}}</text></view><view class="p">{{$root.m6}}<text class="text2">{{activityShowsData.activity_name}}</text></view><view class="p">{{$root.m7}}<text class="text">{{activityShowsData.act_range}}</text></view></view><view class="section"><view class="tit">{{$root.m8}}</view><view class="goods-list"><block wx:if="{{$root.g0}}"><block><block wx:for="{{activityGoodsData}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['detailClick',['$0'],[[['activityGoodsData','',index,'goods_id']]]]]]]}}" class="goods-item" bindtap="__e"><view class="goods-left"><image class="img" src="{{item.goods_thumb}}"></image></view><view class="goods-right"><view class="goods-name twolist-hidden">{{item.goods_name}}</view><view class="plan-box"><view class="price">{{item.shop_price_formated}}<text class="market">{{item.market_price_format}}</text></view></view></view></view></block></block></block><block wx:else><block><dsc-not-content vue-id="44349034-1" bind:__l="__l"></dsc-not-content></block></block></view></view><block wx:if="{{$root.g1}}"><view class="section section2"><view class="tit">{{$root.m9}}</view><view class="goods-list goods-list-lie"><block wx:for="{{activityShowsData.gift}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['detailClick',['$0'],[[['activityShowsData.gift','',index,'id']]]]]]]}}" class="goods-item" bindtap="__e"><view class="goods-img"><image class="img" src="{{item.thumb}}" mode="widthFix"></image></view><view class="goods-info"><view class="goods-name twolist-hidden">{{item.name}}</view><view class="price">{{item.price_formated}}</view></view></view></block></view></view></block></view></block>