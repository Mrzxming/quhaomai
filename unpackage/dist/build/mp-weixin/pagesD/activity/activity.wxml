<scroll-view class="list" scroll-y="{{true}}" data-event-opts="{{[['scrolltolower',[['loadMore',['$event']]]]]}}" bindscrolltolower="__e"><view class="activity"><block wx:for="{{activityIndexData}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['$outerHref',['/pagesD/activity/detail/detail?act_id='+item.act_id,'app']]]]]}}" class="item" bindtap="__e"><view class="pic"><view class="activity-tag"><text class="text tag-gradients-color">{{item.act_type}}</text><view class="sanjiao"></view></view><image class="img" src="{{item.activity_thumb}}" mode="widthFix"></image></view><view class="cont"><view class="tit">{{item.act_name}}</view><view class="time">{{item.start_time+$root.m0+item.end_time}}</view><view class="name">{{item.activity_name}}</view></view></view></block></view></scroll-view>