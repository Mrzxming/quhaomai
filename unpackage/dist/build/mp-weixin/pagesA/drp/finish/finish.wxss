.drp-warp{padding:30rpx}.drp-warp .header{padding:20rpx 0 40rpx}.drp-warp .header .title{font-size:40rpx;color:#333;font-weight:700}.drp-warp .header .subtitle{font-size:25rpx;color:#777}.finish-detail{background:linear-gradient(90deg,#ffb95e,#ec5151);padding:80rpx 0;border-radius:10rpx;position:relative}.finish-detail-warp{display:flex;flex-direction:row}.finish-detail-warp .left{width:180rpx;display:flex;flex-direction:row;justify-content:center}.finish-detail-warp .left .icon{width:100rpx;height:100rpx;border:1px solid #fff;border-radius:100%;display:flex;flex-direction:row;justify-content:center;align-items:center}.finish-detail-warp .left .iconfont{font-size:55rpx;color:#fff}.finish-detail-warp .con{flex:1 1 0%;color:#fff}.finish-detail-warp .con .name{font-size:32rpx}.finish-detail-warp .con .mobile{font-size:25rpx}.finish-detail-warp .more{color:#fff;display:flex;flex-direction:row;justify-content:center;align-items:center}.finish-detail-warp .more text{height:40rpx;line-height:34rpx}.tag{position:absolute;background:linear-gradient(90deg,#ffb95e,#ec5151);padding:4rpx 20rpx;right:0;top:0;border-radius:0 8rpx 0 12rpx;color:#fff;font-size:24rpx}.tips{margin-top:40rpx}.tips .tit{color:#777;font-size:30rpx}.tips .con{color:#777;font-size:25rpx}